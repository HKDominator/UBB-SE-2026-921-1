@model IReadOnlyList<PussyCats.Library.Domain.Chat>
@{
    ViewData["Title"] = "Messages";
}

<div class="container mt-4">
    <h2 class="mb-4">Messages</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No conversations yet.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var c in Model)
            {
                var other = c.SecondUser is not null
                    ? $"{c.SecondUser.FirstName} {c.SecondUser.LastName}".Trim()
                    : c.Company?.CompanyName ?? "Unknown";

                <a asp-action="Show" asp-route-id="@c.ChatId"
                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-start @(c.IsBlocked ? "list-group-item-warning" : "")">
                    <div class="ms-2 me-auto">
                        <div class="fw-semibold">
                            @other
                            @if (c.IsBlocked)
                            {
                                <span class="badge bg-warning text-dark ms-1">Blocked</span>
                            }
                        </div>
                        <small class="text-muted">@c.LastMessageSnippet</small>
                    </div>
                    <div class="text-end">
                        <small class="text-muted d-block">@c.LastMessageTime</small>
                        @if (c.UnreadCount > 0)
                        {
                            <span class="badge bg-primary rounded-pill">@c.UnreadCount</span>
                        }
                    </div>
                </a>
            }
        </div>
    }
</div>
