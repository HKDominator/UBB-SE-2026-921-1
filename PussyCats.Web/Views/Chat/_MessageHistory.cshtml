@using PussyCats.Library.Domain
@using PussyCats.Library.Domain.Enums
@model IEnumerable<Message>

@foreach (var message in Model)
{
    // In a real app, determine 'isMine' based on current user ID
    var isMine = message.Sender.SenderId == 1; 

    <div class="d-flex @(isMine ? "justify-content-end" : "justify-content-start") mb-3">
        @if (!isMine)
        {
            <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center fw-bold me-2 align-self-end" style="width: 28px; height: 28px; font-size: 0.7rem;">
                @message.SenderInitials
            </div>
        }
        
        <div class="max-width-75">
            <div class="p-3 rounded-4 shadow-sm @(isMine ? "bg-primary text-white" : "bg-white border")" 
                 style="border-bottom-@(isMine ? "right" : "left")-radius: 4px !important;">
                
                @if (message.Type == MessageType.Image)
                {
                    <img src="@message.Content" class="img-fluid rounded mb-2" style="max-height: 300px;">
                }
                else if (message.Type == MessageType.File)
                {
                    <div class="d-flex align-items-center mb-1">
                        <i class="bi bi-file-earmark-arrow-down fs-4 me-2"></i>
                        <div>
                            <div class="fw-bold small">Attachment</div>
                            <a href="@message.Content" class="@(isMine ? "text-white" : "text-primary") small">Download</a>
                        </div>
                    </div>
                }
                else
                {
                    <p class="mb-0 small" style="line-height: 1.4;">@message.Content</p>
                }
            </div>
            <div class="d-flex @(isMine ? "justify-content-end" : "justify-content-start") mt-1">
                <small class="text-muted" style="font-size: 0.65rem;">
                    @message.Timestamp.ToString("HH:mm")
                    @if (isMine)
                    {
                        <i class="bi bi-check2-all @(message.IsRead ? "text-primary" : "text-muted") ms-1"></i>
                    }
                </small>
            </div>
        </div>

        @if (isMine)
        {
            <div class="rounded-circle bg-success bg-opacity-10 text-success border border-success border-opacity-25 d-flex align-items-center justify-content-center fw-bold ms-2 align-self-end" style="width: 28px; height: 28px; font-size: 0.7rem;">
                @message.SenderInitials
            </div>
        }
    </div>
}

<style>
    .max-width-75 { max-width: 75%; }
</style>
