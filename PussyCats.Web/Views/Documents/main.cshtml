@model IReadOnlyList<PussyCats.Library.Domain.Document>
@{
    ViewData["Title"] = "Documents Management";
}

<div class="container py-4" style="max-width: 900px;">

    <!-- Top Alert Notification Area (Bootstrap Alert) -->
    @if (ViewBag.StatusMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error:</strong> @ViewBag.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Upload Document Form Card Block (Bootstrap Card with Background Utilities) -->
    <div class="card border-0 bg-dark text-white mb-5 rounded-3 p-2">
        <div class="card-body">
            <h5 class="card-title fw-bold mb-4">Upload Document</h5>
            
            <form asp-action="Upload" method="post" enctype="multipart/form-data" class="needs-validation">
                @Html.AntiForgeryToken()

                <div class="mb-3" style="max-width: 400px;">
                    <label for="txtDocumentName" class="form-label small fw-semibold">Document Name</label>
                    <input type="text" name="documentName" id="txtDocumentName" class="form-control"
                           placeholder="e.g. AWS Certificate 2024" required />
                </div>

                <div class="mb-3">
                    <!-- Bootstrap styled custom-looking file browser element -->
                    <label class="btn btn-light btn-sm me-2" for="filePicker">Browse File...</label>
                    <input type="file" name="file" id="filePicker" accept=".pdf,.jpg,.png" class="d-none" required />
                    <span id="selectedFileLabel" class="small text-white-50">No file selected</span>
                    <div class="form-text text-white-50 small mt-1">Accepted formats: PDF, JPG, PNG</div>
                </div>

                <!-- Validation Output Context -->
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey("file"))
                {
                    <div class="text-warning small fw-bold mb-3">
                        @Html.ValidationMessage("file")
                    </div>
                }

                <button type="submit" class="btn btn-outline-light px-4 mt-2">Upload</button>
            </form>
        </div>
    </div>

    <!-- Uploaded Documents List Section (Bootstrap Flexbox & Background Utilities) -->
    <div class="mb-3">
        <h5 class="fw-bold mb-3">Uploaded Documents</h5>

        @if (Model == null || !Model.Any())
        {
            <p class="text-muted">No documents uploaded yet.</p>
        }
        else
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var doc in Model)
                {
                    <div class="p-3 bg-light rounded-3 d-flex align-items-center justify-content-between border">
                        
                        <div>
                            <div class="fw-semibold text-dark small">@doc.DocumentName</div>
                            <div class="text-muted small">
                                @(doc.UploadDate != default ? doc.UploadDate.ToString("g") : "Date Unavailable")
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <!-- View Link -->
                            <a asp-action="ViewFile" asp-route-id="@doc.DocumentId" target="_blank"
                               class="btn btn-white btn-sm border text-dark px-3">View</a>
                            
                            <!-- Delete Modal Trigger Button -->
                            <button type="button" class="btn btn-white btn-sm border text-dark px-3"
                                    onclick="confirmDeletion('@doc.DocumentId', '@System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(doc.DocumentName)')">
                                Delete
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Web Equivalent of XAML ContentDialog (Pure Bootstrap Modal) -->
<div class="modal fade" id="deleteConfirmationModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold text-dark">Delete Document</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-3">
                <span id="deleteModalMessage" class="text-secondary small">Are you sure you want to delete this document?</span>
            </div>
            <div class="modal-footer border-0 pt-0 justify-content-end">
                <button type="button" class="btn btn-light btn-sm text-secondary px-3" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post" asp-action="Delete">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteDocumentId" value="" />
                    <button type="submit" class="btn btn-danger btn-sm px-3">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Update browser file display matching standard XAML property updates
        document.getElementById('filePicker').addEventListener('change', function (e) {
            const fileName = e.target.files[0] ? e.target.files[0].name : "No file selected";
            document.getElementById('selectedFileLabel').textContent = fileName;
        });

        // Initialize and trigger the Bootstrap Modal via standard API methods
        function confirmDeletion(id, documentName) {
            document.getElementById('deleteDocumentId').value = id;
            document.getElementById('deleteModalMessage').innerHTML = `Are you sure you want to delete "<strong>${documentName}</strong>"?`;
            
            const deleteModal = new bootstrap.Modal(document.getElementById('deleteConfirmationModal'));
            deleteModal.show();
        }
    </script>
}