@model PussyCats.Library.Domain.Skill
@{
    ViewData["Title"] = "Skill Details";
}

<h1>@Model.Name</h1>

<dl class="row">
    <dt class="col-sm-3">Id</dt>
    <dd class="col-sm-9">@Model.SkillId</dd>
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Category</dt>
    <dd class="col-sm-9">@Model.Category</dd>
</dl>

<a class="btn btn-secondary" asp-action="Index">Back to list</a>
<a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.SkillId">Edit</a>