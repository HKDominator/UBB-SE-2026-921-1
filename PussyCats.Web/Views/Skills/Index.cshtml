@model IEnumerable<PussyCats.Library.Domain.Skill>
@{
    ViewData["Title"] = "Skills";
}

<h1>Skills</h1>
<p><a class="btn btn-primary" asp-action="Create">Create New</a></p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Category</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Category</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.SkillId">Details</a> |
                    <a asp-action="Edit" asp-route-id="@item.SkillId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.SkillId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>